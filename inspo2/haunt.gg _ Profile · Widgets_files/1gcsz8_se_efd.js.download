t\n[02:39.45] It rattles my lungs, but my mind is\n[02:43.74] Tangled between your little flaws\n[02:49.78] Your flaws, your flaws, your flaws\n[03:05.15] You're a doll, you are flawless\n[03:12.39] But I just can't wait for love to destroy us\n[03:16.42] I just can't wait for love\n[03:21.08] The only flaw, you are flawless\n[03:28.13] But I just can't wait for love to destroy us\n[03:32.58] I just can't wait for love\n[03:35.65] Wait for love\n[03:38.73] I won't wait for love\n[03:43.87] Wait for love\n[03:46.97] I won't wait for love\n[03:51.75] Wait for love\n[03:53.41]",order:2,audio:{url:"https://assets.haunt.gg/songs/the_neighbourhood-flawless.mp3",mime:"audio/mpeg",width:null,height:null,duration:246},cover:{url:"https://assets.haunt.gg/songs/covers/the_neighbourhood-flawless.png",mime:"image/png",width:null,height:null,duration:null}}],u=s.AudioSettingsSchema.parse({player:!0,playerStyle:"lyrics",lyricsPosition:"below",coverBackground:!0}),d=s.ProfileCustomizationSchema.parse({}),c=s.BorderBlock.parse({}),h=s.BorderAnimationScopeEntrySchema.parse({}),m=[{icon:"solar:microphone-bold",key:"lyrics"},{icon:"solar:gallery-bold",key:"cover"},{icon:"solar:shuffle-bold",key:"controls"}];e.s(["MusicShowcase",0,function(){let e=(0,n.useTranslations)();return(0,t.jsx)("section",{className:"relative w-full overflow-hidden px-6 py-24 md:py-32",children:(0,t.jsxs)("div",{className:"mx-auto flex max-w-6xl flex-col gap-8 text-center lg:text-start",children:[(0,t.jsxs)("div",{className:"inline-flex w-fit items-center gap-2 self-center rounded-4xl border border-[var(--primary-tint-border)] bg-[var(--primary-tint-bg)] px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.3em] text-[var(--primary-tint-text)] lg:self-start",children:[(0,t.jsx)(o.Icon,{icon:"solar:music-note-bold",className:"size-3.5"}),e("landing.music.eyebrow")]}),(0,t.jsxs)("div",{className:"flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:gap-16",children:[(0,t.jsxs)("div",{classNam